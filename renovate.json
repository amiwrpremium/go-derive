{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(deps)",
    ":enableVulnerabilityAlertsWithLabel(security)",
    "group:allNonMajor",
    "schedule:weekly",
    ":automergeMinor",
    ":automergePatch",
    ":automergeDigest",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "labels": ["dependencies"],
  "baseBranches": ["master"],
  "rangeStrategy": "bump",
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on Monday"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  },
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "enabled": false,
      "description": "Don't bump the `go x.y.z` directive in go.mod. Pinning to a specific patch is unnecessarily restrictive for downstream consumers, and CI runs with GOTOOLCHAIN=local so the runner's installed Go must satisfy the directive — bumping it forces matching toolchain installs everywhere."
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "go modules (non-major)"
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["slsa-framework/slsa-github-generator"],
      "enabled": false,
      "description": "SLSA generator's builder-fetch step rejects SHA refs and requires the @vX.Y.Z tag form. Their security model relies on TUF + sigstore signature verification of the builder binary, not SHA-pinning. Documented exception in .github/workflows/pin-check.yml. Don't let Renovate convert the tag back to a SHA — it broke v0.2.12's release pipeline."
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"],
      "description": "Major GitHub Action bumps need manual review — semantics may change between major versions."
    },
    {
      "matchPackageNames": ["github.com/ethereum/go-ethereum"],
      "automerge": false,
      "labels": ["dependencies", "review-required"],
      "description": "go-ethereum touches signing — require manual review"
    },
    {
      "matchPackageNames": ["github.com/gorilla/websocket"],
      "automerge": false,
      "labels": ["dependencies", "review-required"],
      "description": "gorilla/websocket carries the WS transport — require manual review"
    }
  ],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10
}
